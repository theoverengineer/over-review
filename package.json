{
  "name": "over-review",
  "version": "1.0.0",
  "description": "Pull Requests reviewer using AI. Bring Your Own Model, Instant summary, line-by-line comments, and title generation",
  "homepage": "https://github.com/theoverengineer/over-review#readme",
  "bugs": {
    "url": "https://github.com/theoverengineer/over-review/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theoverengineer/over-review.git"
  },
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs",
    "dist": "dist",
    "src": "src"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"package.json\" \"tsconfig.json\" \"tsconfig.test.json\" \"eslint.config.js\" \".prettierrc\" \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"package.json\" \"tsconfig.json\" \"tsconfig.test.json\" \"eslint.config.js\" \".prettierrc\" \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "node --env-file=.env --import tsx src/main.ts",
    "dev:pr": "node scripts/run-dev.js pull_request payloads/pull-request-opened.json",
    "dev:issue-comment": "node scripts/run-dev.js issue_comment payloads/issue-comment-created.json",
    "dev:review-comment": "node scripts/run-dev.js pull_request_review_comment payloads/pull-request-review-comment-created.json"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "ai": "^6.0.206",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
